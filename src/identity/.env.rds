# Environment
NODE_ENV=docker

# Service
SERVICE_NAME=identity service

# Port number
PORT=3333

# JWT
JWT_SECRET=thisisafakesecretchangeit
JWT_ACCESS_EXPIRATION_MINUTES=5
JWT_REFRESH_EXPIRATION_DAYS=1
JWT_REMOTE_INTROSPECTION_ENABLED=true
IDENTITY_SERVICE_BASE_URL=http://identity:3333

# Postgress
POSTGRES_HOST=database-1.cpywaq6ga4gu.ap-south-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_USERNAME=identity_app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_Database=identity
POSTGRES_SYNCHRONIZE=false
POSTGRES_ENTITIES=/../**/*.entity.{js,ts}
POSTGRES_MIGRATIONS=/../**/data/migrations/*.{js,ts}
POSTGRES_MIGRATIONS_RUN=true
POSTGRES_SSL=true
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
PGSSLMODE=no-verify

# Rabbitmq
RABBITMQ_Host=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=identity
RABBITMQ_USE_MESSAGE_ENVELOPE=true
RABBITMQ_PUBLISH_CONFIRM_TIMEOUT_MS=5000

# RETRY
RETRY_COUNT=3
RETRY_FACTOR=2
RETRY_MIN_TIMEOUT=1000
RETRY_MAX_TIMEOUT=60000

# Outbox
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_MAX_ATTEMPTS=20
OUTBOX_RETRY_BASE_MS=5000

# OpenTelemetry
OPEN_TELEMETRY_COLLECTOR_URL=http://localhost:4317
OPEN_TELEMETRY_SERVICE_VERSION=1.0.0
OPEN_TELEMETRY_SERVICE_NAME=identity
