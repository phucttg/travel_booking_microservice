NODE_ENV=development
SERVICE_NAME=payment service
PORT=3377

JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=1
IDENTITY_SERVICE_BASE_URL=http://localhost:3333

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=your_username_here
POSTGRES_PASSWORD=your_password_here
POSTGRES_Database=payment
POSTGRES_SYNCHRONIZE=false
POSTGRES_ENTITIES=/../**/*.entity.{js,ts}
POSTGRES_MIGRATIONS=/../**/data/migrations/*.{js,ts}
POSTGRES_MIGRATIONS_RUN=true
PGSSLMODE=no-verify

RABBITMQ_Host=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=payment
RABBITMQ_USE_MESSAGE_ENVELOPE=true

RETRY_COUNT=3
RETRY_FACTOR=2
RETRY_MIN_TIMEOUT=1000
RETRY_MAX_TIMEOUT=60000

PAYMENT_EXPIRY_SWEEP_MS=60000
PAYMENT_RECEIVER_BANK_NAME=Vietcombank
PAYMENT_RECEIVER_ACCOUNT_NAME=TRAVEL BOOKING COMPANY
PAYMENT_RECEIVER_ACCOUNT_NUMBER=1029384756

OPEN_TELEMETRY_COLLECTOR_URL=http://localhost:4317
OPEN_TELEMETRY_SERVICE_VERSION=1.0.0
OPEN_TELEMETRY_SERVICE_NAME=payment
